# =============================================================================
# ecg-mi-inference 環境変数サンプル
# 使い方: cp .env.sample .env し、値を埋めてください。
# Docker Compose はリポジトリ直下の .env を自動で読み込みます。
# =============================================================================

# -----------------------------------------------------------------------------
# バックエンド認可（必須）
# -----------------------------------------------------------------------------
# JWT 署名鍵。推測困難な長いランダム文字列にしてください。
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# 管理者パスワードは起動後に UI の初回セットアップで DB に保存されます。
# 環境変数での初期投入は行いません。

# アクセストークン有効期限（時間）。未設定時は 8。
# JWT_ACCESS_TOKEN_EXPIRE_HOURS=8

# リフレッシュトークン有効期限（時間）。未設定時は 24。
# JWT_REFRESH_TOKEN_EXPIRE_HOURS=24

# -----------------------------------------------------------------------------
# フォルダ監視（MFER 自動取り込み）— 任意
# 空のままだとウォッチャーは起動しません。
# 相対パスは「カレントディレクトリ」→「リポジトリルート（docker-compose.yml がある階層）」の順で解決します。
# 絶対パス可（例: /Volumes/Share/ecg_in、Windows は D:\inbox や \\fileserver\share\inbox）。
# SMB/NFS 等のネットワーク共有では OS のファイルイベントが不安定なことがあるため、
#   MFER_WATCH_USE_POLLING=1 を推奨（Watchdog の PollingObserver）。
#
# Docker Compose: backend に ./develop が /app/develop にマウントされます。
#   MFER_WATCH_FOLDER=/app/develop/test_data
# ローカル（例: backend ディレクトリから uvicorn）:
#   MFER_WATCH_FOLDER=develop/test_data
# -----------------------------------------------------------------------------
MFER_WATCH_FOLDER=/app/develop/test_data

# 1 / true / yes / on で PollingObserver（ネットワーク共有向け）
# MFER_WATCH_USE_POLLING=1

# ポーリング間隔（秒）。未設定時 1
# MFER_WATCH_POLLING_INTERVAL_SEC=1

# 未設定時 true
# MFER_WATCH_RECURSIVE=true

# 未設定時 5
# MFER_MAX_CONCURRENT=5

# 秒。未設定時 2
# MFER_WRITE_WAIT_INTERVAL=2

# 秒。未設定時 60
# MFER_WRITE_TIMEOUT=60

# 秒。未設定時 30
# MFER_SHUTDOWN_TIMEOUT=30

# 未設定時 10000
# MFER_TRACKING_LIMIT=10000

# 秒。未設定時 300（統計ログ間隔）
# MFER_STATS_INTERVAL=300

# -----------------------------------------------------------------------------
# BNP 推論（ECG→BNP）— 任意
# backend ディレクトリからの相対パス（app.bnp_inference が backend ルートで解決）。
# -----------------------------------------------------------------------------
# ECG_BNP_INFERENCE_CONFIG=config/bnp_infer.yaml

# -----------------------------------------------------------------------------
# ファイルインポート（MFER 移動先）— 任意
# 未設定時は backend カレント相対の ./processed と ./error
#
# Docker Compose（docker-compose.yml の backend）では compose 側で
#   MFER_PROCESSED_FOLDER=/app/processed と MFER_ERROR_FOLDER=/app/error
# が上書き設定されます（DB にコンテナパスが入り、./backend/processed 等の
# バインドマウントと一致します）。ローカル uvicorn のときだけ下を使う想定です。
# -----------------------------------------------------------------------------
# MFER_PROCESSED_FOLDER=./processed
# MFER_ERROR_FOLDER=./error

# -----------------------------------------------------------------------------
# Docker Compose（compose.yml が参照）
# -----------------------------------------------------------------------------
# backend サービスに渡されます。既定はインメモリSQLite（再起動で消える）。
# ファイルDBに切り戻す場合は以下を使ってください:
#   DATABASE_URL=sqlite:////app/data/ecg_mi.db
DATABASE_URL=sqlite:///:memory:
# サンプルSeed投入は既定で無効。必要時のみ 1 を設定。
# ECG_MI_ENABLE_SAMPLE_DB_SEED=1
# APP_LOG_LEVEL=INFO
# ECG_MI_EPHEMERAL_MODE=1

# -----------------------------------------------------------------------------
# フロントエンド（Vite ローカル開発）— 任意
# docker-compose の frontend は compose 内で VITE_* を設定済み。
# -----------------------------------------------------------------------------
# ブラウザから叩く API のベース（末尾に /api を含む想定の場合あり。プロジェクトの apiFetch と要整合）
# VITE_API_URL=http://localhost:8000/api

# dev サーバのプロキシ先（未設定時は VITE_API_URL または http://localhost:8000）
# VITE_PROXY_TARGET=http://localhost:8000
